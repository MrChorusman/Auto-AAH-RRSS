# Copia a .env y rellena. Todas las APIs tienen plan gratuito.

# RSS del podcast (Ivoox - en la página del podcast suele haber "RSS" o "Suscribirse")
RSS_URL=https://www.ivoox.com/podcast-a-altas-horas_fg_f166011_filtro_1.xml

# Telegram (crea un bot con @BotFather, luego envía /start a tu bot y usa el chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X / Twitter (Developer Portal: developer.twitter.com -> proyecto y app -> API Key & Secret, Bearer, Access Token)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Opcional: copy con IA (Groq es gratis - groq.com)
GROQ_API_KEY=

# Ruta del logo (por defecto la de este proyecto)
LOGO_PATH=/Applications/Auto AAH RRSS/aahoras_logo.jpeg

# Enlace del programa
LINK_BIO=https://t.co/6JkMQXIgit
# En X, usar enlace directo en el texto del post
LINK_X=https://t.co/6JkMQXIgit
